	doi = {10.23919/FUSION65864.2025.11123934},
	abstract = {Accurately estimating articulation angle, coupling force, and lateral velocity in articulated heavy vehicles is critical for accident prevention and energy efficiency. However, despite their importance, these quantities - especially the coupling force - have received limited attention in terms of practical and computationally efficient estimation methods. To bridge this gap, we propose a novel modeling approach that conceptualizes the coupling as a rigid damper. This formulation significantly reduces computational complexity while maintaining high estimation accuracy. Within a Bayesian estimation framework, we employ an unscented Kalman filter (UKF) for real-time inference of the vehicle states. We validate our method on high-fidelity simulation data with realistic scenarios and sensor noise. The results demonstrate the effectiveness of our method, highlighting its potential for enhancing vehicle safety and performance in practical applications.},
	urldate = {2026-04-29},
	booktitle = {2025 28th {International} {Conference} on {Information} {Fusion} ({FUSION})},
	author = {Ceder, Axel and Hammarstrand, Lars and Jonasson, Mats and Kumru, Murat and Laine, Leo},
	month = jul,
	year = {2025},
	keywords = {Articulation Angle, Bayes methods, Coupling force, Couplings, Estimation, Force, Lateral Velocity, Noise, Real-time estimation, Robustness, Safety, Shock absorbers, Tractor-semitrailer combination, Uncertainty, Vehicle dynamics},
	pages = {1--8},
	file = {Full Text PDF:C\:\\Users\\axel\\Zotero\\storage\\BXKIIVGU\\Ceder m. fl. - 2025 - Bayesian Motion Estimation for Articulated Heavy Vehicles\; A Damper-Based Model for Coupling Force.pdf:application/pdf;Full Text PDF:C\:\\Users\\axel\\Zotero\\storage\\JZ4249MQ\\Ceder et al. - 2025 - Bayesian Motion Estimation for Articulated Heavy Vehicles\; A Damper-Based Model for Coupling Force.pdf:application/pdf},
