	keywords = {Mathematical model, Approximation algorithms, Covariance matrix, Filtering, Measurement errors, Measurement uncertainty, Vectors},
	pages = {1669--1681},
	file = {IEEE Xplore Abstract Record:C\:\\Users\\axel\\Zotero\\storage\\EBC2ZIMM\\6178086.html:text/html},
}

