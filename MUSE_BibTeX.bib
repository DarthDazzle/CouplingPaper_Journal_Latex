	keywords = {fleet sizing, freight transportation, heterogeneous heavy-vehicle fleet, hybrid and electric vehicles, logistics and electromobility, propulsion tailoring},
	pages = {3221},
	file = {Full Text PDF:C\:\\Users\\axel\\Zotero\\storage\\HUNYRH2E\\Ghandriz et al. - 2021 - Transportation-Mission-Based Optimization of Heter.pdf:application/pdf;Snapshot:C\:\\Users\\axel\\Zotero\\storage\\A952XHL6\\htm.html:text/html},
}

